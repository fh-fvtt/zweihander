<fieldset>
  <legend>{{localize 'ZWEI.actor.items.innateability'}}</legend>
  <div class="form-group stacked">
    <label>{{localize "ZWEI.actor.items.effect"}}</label>
    <prose-mirror
      name="{{zhLocalizePath 'system.rules.effect'}}"
      value="{{zhLocalize system.rules.effect}}"
      toggled="true"
    >
      {{{html.rules.effect}}}
    </prose-mirror>
  </div>
</fieldset>

<fieldset>
  <legend>{{localize 'ZWEI.actor.items.misc'}}</legend>
  <div class="form-group stacked">
    <label>{{localize 'ZWEI.actor.items.category'}}</label>
    <select name="system.category">
      {{#each choices.traitCategories}}
        <option value="{{value}}" {{selected}}>{{label}}</option>
      {{/each}}
    </select>
  </div>
</fieldset>